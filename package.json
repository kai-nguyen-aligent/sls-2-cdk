{
  "name": "sls-2-cdk",
  "version": "0.1.0",
  "description": "Convert Serverless Framework projects to AWS CDK",
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sls-2-cdk": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "oclif": {
    "bin": "sls-2-cdk",
    "dirname": "sls-2-cdk",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "dev": "pnpm run build && pnpm run prepack && ./bin/dev.js",
    "prepare": "pnpm run build",
    "prepack": "oclif manifest && oclif readme",
    "postpack": "rm -f oclif.manifest.json",
    "lint": "eslint . --ext .ts",
    "posttest": "pnpm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@oclif/core": "^4",
    "ts-morph": "^27.0.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@aligent/ts-code-standards": "^4.2.0",
    "@oclif/test": "^4",
    "@types/node": "^22",
    "eslint": "^9",
    "oclif": "^4",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shx": "^0.3",
    "ts-node": "^10",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3"
  }
}
